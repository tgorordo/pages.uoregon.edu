  3.9685105906437693`*^9}},ExpressionUUID->"eefec0b3-3561-46a2-a6e9-\
ddd2e822f15e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"SOLa", " ", "=", " ", 
  RowBox[{"Solve", "[", 
   RowBox[{
    RowBox[{"0", " ", "==", " ", 
     FractionBox[
      RowBox[{
       RowBox[{"m", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"x1", "[", "t", "]"}], " ", "+", " ", 
          RowBox[{"x2", "[", "t", "]"}]}], ")"}]}], " ", "+", " ", 
       RowBox[{"M", " ", 
        RowBox[{"X", "[", "t", "]"}]}]}], 
      RowBox[{
       RowBox[{"2", "m"}], " ", "+", " ", "M"}]]}], ",", 
    RowBox[{"X", "[", "t", "]"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.968510734332603*^9, 3.96851083092476*^9}, {
  3.968512672386313*^9, 3.9685126733087997`*^9}},
 CellLabel->"In[28]:=",ExpressionUUID->"8b37e1ca-d314-4dc7-982f-7965da0ad021"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"X", "[", "t", "]"}], "\[Rule]", 
    RowBox[{"-", 
