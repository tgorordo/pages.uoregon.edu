     RowBox[{
      RowBox[{"\[Delta]X", "''"}], "[", "t", "]"}], "==", 
     RowBox[{"D", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"x2", "[", "t", "]"}], "-", 
        RowBox[{"x1", "[", "t", "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "2"}], "}"}]}], "]"}]}], "/.", 
    RowBox[{"Solve", "[", 
     RowBox[{"EOM", ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"x1", "''"}], "[", "t", "]"}], ",", 
        RowBox[{
         RowBox[{"x2", "''"}], "[", "t", "]"}]}], "}"}]}], "]"}]}], "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"x2", "[", "t", "]"}], "->", 
     RowBox[{
      RowBox[{"\[Delta]X", "[", "t", "]"}], "+", 
      RowBox[{"x1", "[", "t", "]"}]}]}], "}"}]}], "//", "Simplify"}]], "Input",\

 CellChangeTimes->{{3.968516723684477*^9, 3.968516818027755*^9}},
 CellLabel->"In[49]:=",ExpressionUUID->"c898f2ca-1720-475c-b935-57a807304c1b"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{
    SuperscriptBox["\[Delta]X", "\[Prime]\[Prime]",
     MultilineFunction->None], "[", "t", "]"}], "\[Equal]", 
   FractionBox[
    RowBox[{"k", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", " ", "d"}], "-", 
       RowBox[{"\[Delta]X", "[", "t", "]"}]}], ")"}]}], "m"]}], 
  "}"}]], "Output",
 CellChangeTimes->{{3.9685167495877047`*^9, 3.96851677579539*^9}, {
   3.9685168112679167`*^9, 3.96851681869829*^9}, 3.968782634214826*^9, 
   3.9695383805020247`*^9},
 CellLabel->"Out[49]=",ExpressionUUID->"e1e6579d-1532-469e-986e-d5fc3029f044"]
}, Open  ]],

